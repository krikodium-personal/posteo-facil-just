
# Dash API requires a Bearer Token.
# Client ID and Secret cannot be used directly (Client Credentials flow is not supported).
#
# To get a token for testing:
# 1. Log in to your Dash account in your browser.
# 2. Open Developer Tools (F12 or Cmd+Opt+I).
# 3. Go to Application > Local Storage > https://dash.app
# 4. Copy the value of 'access_token'.
#
VITE_FACEBOOK_APP_ID=2304873133350798
VITE_DROPBOX_ROOT_PATH=/Apps/Posteo Facil

# TikTok API
VITE_TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
VITE_TIKTOK_REDIRECT_URI=http://localhost:5173/auth/tiktok/callback

VITE_INSTAGRAM_REDIRECT_URI=http://localhost:5173/auth/instagram/callback
INSTAGRAM_APP_SECRET=your_instagram_app_secret
